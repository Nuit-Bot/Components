{
    "compilerOptions": {
        "target": "ESNext",
        "module": "Preserve",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "verbatimModuleSyntax": true,
        "lib": ["ES2022", "DOM"],
        "moduleDetection": "force"
    },
    "include": ["src"]
}
